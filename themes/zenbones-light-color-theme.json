  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9EA090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5E6F7C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String Escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": {
        "foreground": "#88507D",
        "fontStyle": ""
      }
    },
    {
      "name": "Number, Boolean, Constant",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#5E6F7C",
        "fontStyle": ""
      }
    },
    {
      "name": "Boolean",
      "scope": ["constant.language.boolean"],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.accessor",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#787270",
        "fontStyle": ""
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": ""
      }
    },
    {
      "name": "Function Declaration",
      "scope": ["entity.name.function", "meta.definition.function"],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter",
        "support.variable"
      ],
      "settings": {
        "foreground": "#475865",
        "fontStyle": ""
      }
    },
    {
      "name": "Variable Language (this, self)",
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#475865",
        "fontStyle": ""
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#7A7570",
        "fontStyle": ""
      }
    },
    {
      "name": "Interface, Enum",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.alias",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#7A7570",
        "fontStyle": ""
      }
    },
    {
      "name": "Type Parameter",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#7A7570",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Special",
      "scope": ["entity.other.attribute-name", "support.other"],
      "settings": {
        "foreground": "#596A76",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#787270",
        "fontStyle": ""
      }
    },
    {
      "name": "Delimiter",
      "scope": ["punctuation.terminator", "punctuation.separator.comma"],
      "settings": {
        "foreground": "#787270",
        "fontStyle": ""
      }
    },
    {
      "name": "Tag (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx",
        "entity.other.attribute-name.js"
      ],
      "settings": {
        "foreground": "#596A76",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css", "support.type.vendored.property-name.css"],
      "settings": {
        "foreground": "#475865",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "constant.numeric.css",
        "constant.other.color.rgb-value.hex.css",
        "support.constant.color.w3c-standard-color-name.css"
      ],
      "settings": {
        "foreground": "#5E6F7C",
        "fontStyle": ""
      }
    },
    {
      "name": "CSS Unit",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#5E6F7C",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "heading.4.markdown",
        "heading.5.markdown",
        "heading.6.markdown",
        "markup.heading",
        "markup.heading.setext",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": {
        "foreground": "#2C363C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#286486",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#5E6F7C",
        "fontStyle": ""
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote.markdown"],
      "settings": {
        "foreground": "#9EA090",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List",
      "scope": ["markup.list", "punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#596A76",
        "fontStyle": ""
      }
    },
    {
      "name": "Diff Inserted",
